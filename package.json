{
  "name": "tanstack-rest-query",
  "version": "0.1.0",
  "description": "Define REST resources once and generate TanStack Query configs without wrapping TanStack Query.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.test-d.json",
    "prepublishOnly": "npm run typecheck && npm run test && npm run test:types && npm run build"
  },
  "keywords": [
    "tanstack-query",
    "react-query",
    "rest",
    "api-client",
    "query",
    "resource",
    "builder",
    "fetch",
    "typescript"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.80.0",
    "@types/node": "^22.15.21",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}

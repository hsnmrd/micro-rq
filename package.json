{
  "name": "micro-rq",
  "version": "0.1.0",
  "description": "Define REST resources once and generate TanStack Query configs without wrapping TanStack Query.",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsnmrd/micro-rq.git"
  },
  "bugs": {
    "url": "https://github.com/hsnmrd/micro-rq/issues"
  },
  "homepage": "https://github.com/hsnmrd/micro-rq#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.test-d.json",
    "release:check": "npm run typecheck && npm run test && npm run test:types && npm run build && npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run test:types && npm run build"
  },
  "keywords": [
    "tanstack-query",
    "react-query",
    "rest",
    "api-client",
    "query",
    "resource",
    "builder",
    "fetch",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.80.0",
    "@types/node": "^22.15.21",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
